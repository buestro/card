---
import type { ProfileConfig } from "@/config/types";
import SocialLink from "./SocialLink.astro";

interface Props {
  profile: ProfileConfig;
}

const { profile } = Astro.props;

const initials = profile.name
  .split(" ")
  .map((n) => n[0])
  .slice(0, 2)
  .join("")
  .toUpperCase();
---

<article class="card" aria-label={`${profile.name}'s profile`}>
  <!-- ── Left panel ── -->
  <div class="panel-left">
    <!-- Avatar + handle -->
    <div class="avatar-group">
      <div class="avatar-wrap">
        {
          profile.avatar ? (
            <img
              src={profile.avatar}
              alt={`${profile.name}'s avatar`}
              class="avatar-img"
              width="120"
              height="120"
              loading="eager"
              decoding="async"
            />
          ) : (
            <div class="avatar-fallback" aria-hidden="true">
              {initials}
            </div>
          )
        }
      </div>
      {profile.handle && <p class="handle">{profile.handle}</p>}
    </div>

    <!-- Tech tags -->
    <ul class="tags" aria-label="Tech stack" role="list">
      {profile.tags.map((tag) => <li class="tag">{tag}</li>)}
    </ul>
  </div>

  <!-- ── Right panel ── -->
  <div class="panel-right">
    <!-- Identity -->
    <div class="identity">
      <h1 class="name">{profile.name}</h1>
      {profile.tagline && <p class="tagline">{profile.tagline}</p>}
      {profile.bio && <p class="bio">{profile.bio}</p>}
    </div>

    <!-- CTA button -->
    {
      profile.cta && (
        <a
          href={profile.cta.url}
          class="cta-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          {profile.cta.label}
          <span class="cta-arrow" aria-hidden="true">
            ↗
          </span>
        </a>
      )
    }

    <!-- Divider -->
    <hr class="divider" />

    <!-- Social links grid -->
    <nav class="links" aria-label="Social links">
      {profile.links.map((link) => <SocialLink item={link} />)}
    </nav>

    <!-- Attribution -->
    <footer class="attribution">
      <a
        href="https://buestro.com/card"
        target="_blank"
        rel="noopener noreferrer"
      >
        Made with Buestro Card · Get Pro
      </a>
    </footer>
  </div>
</article>

<style>
  /* ── Card shell ── */
  .card {
    display: grid;
    grid-template-columns: 2fr 3fr;
    width: 100%;
    max-width: 52rem;
    min-height: 26rem;
    border-radius: 1.25rem;
    border: 1px solid var(--border-default);
    background-color: var(--bg-surface);
    overflow: hidden;
    box-shadow:
      0 4px 32px rgba(16, 185, 129, 0.1),
      0 1px 4px rgba(0, 0, 0, 0.06);
  }

  @media (prefers-color-scheme: dark) {
    .card {
      box-shadow: none;
    }
  }

  /* ── Left panel ── */
  .panel-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 1.75rem 1.5rem;
    border-right: 1px solid var(--border-default);
  }

  /* Avatar + handle group */
  .avatar-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  /* Avatar */
  .avatar-wrap {
    width: 7.5rem;
    height: 7.5rem;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--accent-muted);
    flex-shrink: 0;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--accent-subtle);
    color: var(--accent);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  /* Handle */
  .handle {
    margin: 0;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.01em;
  }

  /* Tech tags */
  .tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.375rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-muted);
    padding: 0.25rem 0.625rem;
    border-radius: 0.375rem;
    border: 1px solid var(--border-default);
    background-color: var(--bg-subtle);
    letter-spacing: 0.02em;
    line-height: 1.4;
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }

  .tag:hover {
    border-color: var(--accent-muted);
    color: var(--accent);
  }

  /* ── Right panel ── */
  .panel-right {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
    padding: 1.75rem 1.75rem 1.25rem;
  }

  /* Identity */
  .identity {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .name {
    margin: 0;
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .tagline {
    margin: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .bio {
    margin: 0.25rem 0 0;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* CTA button */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    align-self: flex-start;
    padding: 0.5625rem 1.125rem;
    border-radius: 0.5rem;
    background-color: var(--accent);
    color: #022c22;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .cta-btn:hover {
    background-color: var(--accent-hover);
    color: #fff;
  }

  .cta-arrow {
    font-size: 0.8125rem;
    opacity: 0.85;
  }

  /* Divider */
  .divider {
    border: none;
    border-top: 1px solid var(--border-default);
    margin: 0;
  }

  /* Links grid */
  .links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  /* Attribution */
  .attribution {
    margin-top: auto;
  }

  .attribution a {
    font-size: 0.6875rem;
    color: var(--text-muted);
    text-decoration: none;
    opacity: 0.55;
    transition:
      opacity 0.15s ease,
      color 0.15s ease;
  }

  .attribution a:hover {
    opacity: 1;
    color: var(--accent);
  }

  /* ── Responsive: stack on mobile ── */
  @media (max-width: 640px) {
    .card {
      grid-template-columns: 1fr;
      max-width: 26rem;
      min-height: unset;
    }

    .panel-left {
      border-right: none;
      border-bottom: 1px solid var(--border-default);
      padding: 1.5rem 1.25rem;
    }

    .avatar-wrap {
      width: 6rem;
      height: 6rem;
      margin-top: 0.5rem;
    }

    .panel-right {
      padding: 1.5rem 1.25rem 1.25rem;
    }

    .name {
      font-size: 1.5rem;
    }

    .links {
      grid-template-columns: 1fr;
    }
  }
</style>
