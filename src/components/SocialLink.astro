const defaultLabels: Record<Platform, string> = {
  github:    "GitHub",
  linkedin:  "LinkedIn",
  twitter:   "Twitter / X",
  instagram: "Instagram",
  youtube:   "YouTube",
  tiktok:    "TikTok",
  twitch:    "Twitch",
  bluesky:   "Bluesky",
  mastodon:  "Mastodon",
  threads:   "Threads",
  email:     "Email",
  website:   "Website",
};

const label    = item.label ?? defaultLabels[item.platform];
const iconPath = icons[item.platform];
const isEmail  = item.platform === "email";
---

<a
  href={item.url}
  class="social-link"
  target={isEmail ? "_self" : "_blank"}
  rel={isEmail ? undefined : "noopener noreferrer"}
  aria-label={`${defaultLabels[item.platform]}${label ? `: ${label}` : ""}`}
>
  <span class="icon" aria-hidden="true">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      width="18"
      height="18"
    >
      <path d={iconPath} />
    </svg>
  </span>

  <span class="link-content">
    <span class="platform-name">{defaultLabels[item.platform]}</span>
    {label && <span class="link-label">{label}</span>}
  </span>

  <span class="arrow" aria-hidden="true">↗</span>
</a>

<style>
  .social-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 0.875rem;
    border-radius: var(--radius-link);
    border: 1px solid var(--border-default);
    background-color: var(--bg-subtle);
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .social-link:hover {
    border-color: var(--accent);
    background-color: var(--accent-subtle);
  }

  .social-link:hover .platform-name {
    color: var(--accent);
  }

  .social-link:hover .arrow {
    color: var(--accent);
    opacity: 1;
  }

  .icon {
    display: flex;
    align-items: center;
    color: var(--accent);
    flex-shrink: 0;
  }

  .link-content {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
    min-width: 0;
  }

  .platform-name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.2;
    transition: color 0.15s ease;
  }

  .link-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: "JetBrains Mono", monospace;
    line-height: 1.2;
  }

  .arrow {
    font-size: 0.75rem;
    color: var(--text-muted);
    opacity: 0.6;
    flex-shrink: 0;
    transition: color 0.15s ease, opacity 0.15s ease;
  }
</style>
